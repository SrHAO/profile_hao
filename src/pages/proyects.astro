---
import Layout from "../layouts/layout.astro";
import ImageCarousel from "../components/ImageCarousel.astro";
import "../styles/proyect.css";

const projectImages = [
  {
    src: "https://picsum.photos/1200/675?random=1",
    alt: "Project 1",
    title: "Project One",
    description: "A modern web application built with React and Node.js",
  },
  {
    src: "https://picsum.photos/1200/675?random=2",
    alt: "Project 2",
    title: "Project Two",
    description: "E-commerce platform with payment integration",
  },
  {
    src: "https://picsum.photos/1200/675?random=3",
    alt: "Project 3",
    title: "Project Three",
    description: "Portfolio website with animations",
  },
  {
    src: "https://picsum.photos/1200/675?random=4",
    alt: "Project 4",
    title: "Project Four",
    description: "Mobile-first responsive design",
  },
  {
    src: "https://picsum.photos/1200/675?random=5",
    alt: "Project 5",
    title: "Project Five",
    description: "Dashboard with data visualization",
  },
];
---

<Layout title="Projects - Web Developer Profile">
  <div class="container mx-auto px-4 md:px-8 lg:px-16 py-20 max-w-7xl">
    <h1
      class="proyects-title"
      data-translate
      data-en="Projects"
      data-es="Proyectos"
    >
      Proyects
    </h1>

    <div class="carousel-wrapper">
      <ImageCarousel images={projectImages} />
    </div>
    <div
      class="mt-8 md:mt-12 p-6 md:p-8 bg-white/80 dark:bg-gray-800/80 backdrop-blur-md rounded-2xl shadow-xl border border-gray-200/50 dark:border-gray-700/50 mx-auto max-w-4xl text-center text-base md:text-lg leading-relaxed text-gray-700 dark:text-gray-300 transition-all duration-500 hover:shadow-2xl"
    >
      <p
        data-translate
        data-en="There are currently no projects available. However, this space will be updated soon, and the images will be replaced with working projects. In the meantime, enjoy the images shown."
        data-es="Actualmente no hay proyectos disponibles. Sin embargo, este espacio se actualizará pronto y las imágenes se reemplazarán con proyectos funcionales. Mientras tanto, disfruta de las imágenes mostradas."
      >
        There are currently no projects available. However, this space will be
        updated soon, and the images will be replaced with working projects. In
        the meantime, enjoy the images shown.
      </p>
    </div>
  </div>
</Layout>
