---
import Layout from "../layouts/layout.astro";
import "../styles/about.css";
---

<Layout title="About - Web Developer Profile">
  <div class="container mx-auto px-4 md:px-8 lg:px-16 py-20 max-w-7xl">

    <h1 
      class="about-title"
      data-translate
      data-en="About"
      data-es="Acerca de">
      About
    </h1>
    
    <div class="about-content">

      <!-- Introduction Section -->
      <section class="about-section">

        <h2 
          data-translate
          data-en="Introduction"
          data-es="Introducción">
          Introduction
        </h2>

        <p
          data-translate
          data-en="Hello! I am a passionate web developer with experience creating modern, responsive, and user-friendly web applications. I enjoy building elegant solutions to complex problems and continuously learning new technologies."
          data-es="¡Hola! Soy un desarrollador web apasionado con experiencia en la creación de aplicaciones web modernas, responsivas y fáciles de usar. Me encanta crear soluciones elegantes a problemas complejos y aprender continuamente nuevas tecnologías.">
          ¡Hola! Soy un desarrollador web apasionado...
        </p>

      </section>


      <!-- Skills Section -->
      <section class="about-section" id="skills">

        <h2
          data-translate
          data-en="Skills"
          data-es="Habilidades">
          Skills
        </h2>

        <div class="skills-grid">

          <div class="skill-item">JavaScript</div>
          <div class="skill-item">TypeScript</div>
          <div class="skill-item">React</div>
          <div class="skill-item">Astro</div>
          <div class="skill-item">Node.js</div>
          <div class="skill-item">HTML/CSS</div>
          <div class="skill-item">Tailwind CSS</div>
          <div class="skill-item">Git</div>

        </div>
      </section>


      <!-- Experience Section -->
      <section class="about-section" id="experience">

        <h2
          data-translate
          data-en="Experience"
          data-es="Experiencia">
          Experience
        </h2>
        
        <div class="experience-item">

          <h3
            data-translate
            data-en="Web Developer"
            data-es="Desarrollador Web">
            Web Developer
          </h3>

          <p class="date">2023 - Present</p>

          <p
            class="description"
            data-translate
            data-en="Creating modern web applications using React, Astro, and other modern technologies. Focused on building responsive and accessible user interfaces."
            data-es="Creando aplicaciones web modernas usando React, Astro y otras tecnologías modernas. Enfocado en crear interfaces de usuario responsivas y accesibles.">
            Creando aplicaciones web modernas usando React...
          </p>

        </div>
        
        <div class="experience-item">

          <h3
            data-translate
            data-en="Frontend Developer"
            data-es="Desarrollador Frontend">
            Frontend Developer
          </h3>

          <p class="date">2021 - 2023</p>

          <p
            class="description"
            data-translate
            data-en="I developed and maintained websites for clients using HTML, CSS, and JavaScript. Collaborated with design teams to implement pixel-perfect layouts."
            data-es="Desarrollé y mantuve sitios web para clientes usando HTML, CSS y JavaScript. Colaboré con equipos de diseño para implementar diseños perfectos.">
            Desarrollé y mantuve sitios web...
          </p>

        </div>

      </section>


      <!-- Education Section -->
      <section class="about-section">

        <h2
          data-translate
          data-en="Education"
          data-es="Educación">
          Education
        </h2>

        <div class="experience-item">

          <h3
            data-translate
            data-en="Computer Science Degree"
            data-es="Grado en Ciencias de la Computación">
            Computer Science Degree
          </h3>

          <p class="date">2017 - 2021</p>

          <p
            class="description"
            data-translate
            data-en="I studied computer science with a focus on web development and software engineering."
            data-es="Estudié ciencias de la computación con enfoque en desarrollo web e ingeniería de software.">
            Estudié ciencias de la computación...
          </p>

        </div>

      </section>

    </div>
  </div>
</Layout>
