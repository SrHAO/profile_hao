---
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import CVButton from "../components/CVButton.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const {
  title,
  lang = "en",
  description = "Web Developer Portfolio - Showcasing projects and skills",
} = Astro.props;
---

<!doctype html>
<html lang={Astro.props.lang || "en"} id="html-lang">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content={description} />

    <title>{title}</title>

    <script is:inline>
      (function () {
        // Initialize language first (default to 'en')
        let storedLang = localStorage.getItem("lang");
        if (!storedLang) {
          storedLang = "en";
          localStorage.setItem("lang", storedLang);
        }
        document.documentElement.lang = storedLang;

        /* Initializes dark mode from localStorage on page load */
        const storedTheme = localStorage.getItem("theme");
        if (storedTheme === "dark" || !storedTheme) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col transition-colors duration-300">
    <Sidebar />

    <main class="flex-1">
      <slot />
    </main>

    <CVButton/>

    <Footer />

    <BackToTop />
  </body>
</html>
