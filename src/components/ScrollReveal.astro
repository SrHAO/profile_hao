---
/* Imports CardFlip component and scroll-reveal CSS styles */
import CardFlip from "./CardFlip.astro";
import "../styles/scroll-reveal.css";
---

<script is:inline>
  /* Initializes all reveal animations and event listeners */
  const initReveal = () => {
    /* Selects all reveal elements for intersection observer */
    const elements = document.querySelectorAll(
      ".reveal, .reveal-left, .reveal-right, .reveal-scale",
    );

    /* Creates observer that triggers animations when elements enter viewport */
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("active");
          }
        });
      },
      { threshold: 0.2 },
    );

    /* Attaches observer to all reveal elements */
    elements.forEach((el) => observer.observe(el));

    /* Selects flip cards for click interaction */
    const flipCards = document.querySelectorAll(".profile-flip");

    /* Adds click listener to each flip card */
    flipCards.forEach((card) => {
      card.addEventListener("click", () => {
        /* Toggles flipped class for 3D rotation */
        card.classList.toggle("flipped");

        /* Toggles about info visibility if element exists */
        const info = card
          .closest(".about-container")
          ?.querySelector(".about-info");
        if (info) {
          if (card.classList.contains("flipped")) {
            info.classList.add("show");

            setTimeout(() => {
              const texts = info.querySelectorAll(".typewriter");

              texts.forEach((el, index) => {
                const textLength = el.textContent.length;
                const duration = textLength * 0.05;

                setTimeout(() => {
                  el.style.setProperty("--duration", `${duration}s`);
                  el.classList.add("animate");
                }, index * 500);
              });
            }, 400);
          } else {
            info.classList.remove("show");

            // reset animación
            const texts = info.querySelectorAll(".typewriter");
            texts.forEach((el) => {
              el.classList.remove("animate");
              el.style.removeProperty("--duration");
              void el.offsetWidth;
            });
          }
        }
      });
    });
  };

  /* Runs on DOM load and Astro page load */
  document.addEventListener("DOMContentLoaded", initReveal);
  document.addEventListener("astro:page-load", initReveal);
</script>

<section class="py-20 max-w-6xl mx-auto px-6">
  <h1
    class="reveal text-4xl md:text-5xl font-bold mb-12 text-center"
    data-translate
    data-en="About Me"
    data-es="Sobre mí"
  >
    Sobre mí
  </h1>
  <div class="about-container">
    <CardFlip />
    <h5
      class="reveal text-xl md:text-2xl font-bold text-center mt-8 mb-6 cursor-pointer mx-auto max-w-sm px-4"
      data-translate
      data-en="Click on the image"
      data-es="Has click en la imagen"
    >
      Has click en la imagen
    </h5>
    <div class="about-info" id="about-info">
      <h2
        class="text-4xl md:text-5xl font-bold mt-0 mb-6"
        data-translate
        data-en="Frontend Developer"
        data-es="Desarrollador Front-End"
      >
        Frontend Developer
      </h2>
      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en="Specialized in web and mobile applications. Experienced in React, HTML,
        CSS, React Native, and Astro. Building modern interfaces with an
        emphasis on visual consistency, performance, and accessibility."
        data-es="Especializado en aplicaciones web y móviles. Experiencia en React, HTML, CSS, React Native y Astro. Construcción de interfaces modernas con énfasis en consistencia visual, rendimiento y accesibilidad."
      >
        Specialized in web and mobile applications. Experienced in React, HTML,
        CSS, React Native, and Astro. Building modern interfaces with an
        emphasis on visual consistency, performance, and accessibility.
      </p>
      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en="On the web, implementation of reusable components, efficient state
        management, and rendering optimization. Use of Astro for
        content-oriented architectures with minimal client-side JavaScript."
        data-es="En web, implementación de componentes reutilizables, manejo eficiente del estado y optimización de renderizado. Uso de Astro para arquitecturas orientadas a contenido con mínima carga de JavaScript en cliente."
      >
        On the web, implementation of reusable components, efficient state
        management, and rendering optimization. Use of Astro for
        content-oriented architectures with minimal client-side JavaScript.
      </p>
      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en=" On mobile, development of cross-platform applications with React Native,
        prioritizing native performance and interface consistency"
        data-es="En móvil, desarrollo de aplicaciones multiplataforma con React Native, priorizando rendimiento nativo y coherencia de interfaz."
      >
        On mobile, development of cross-platform applications with React Native,
        prioritizing native performance and interface consistency
      </p>
      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en="Focus on scalable systems: separation of responsibilities, reduction of
        unnecessary complexity, and elimination of redundant state."
        data-es="Enfoque en sistemas escalables: separación de responsabilidades, reducción de complejidad innecesaria y eliminación de estado redundante."
      >
        Focus on scalable systems: separation of responsibilities, reduction of
        unnecessary complexity, and elimination of redundant state.
      </p>

      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en="Active learning in AI-assisted development, continuous adaptation to new
        practices."
        data-es="Aprendizaje activo en desarrollo asistido por IA, adaptación continua a nuevas prácticas."
      >
        Active learning in AI-assisted development, continuous adaptation to new
        practices.
      </p>

      <p
        class="text-2xl md:text-1xl font-width mt-0 mb-3 typewriter"
        data-translate
        data-en="Focus on clean, maintainable, predictable, and optimized code."
        data-es="Orientación a código limpio, mantenible, predecible y optimizado."
      >
        Focus on clean, maintainable, predictable, and optimized code.
      </p>
    </div>
  </div>
</section>
