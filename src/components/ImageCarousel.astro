---
import "../styles/carousel.css";

interface Props {
  images: {
    src: string;
    alt: string;
    title?: string;
    description?: string;
  }[];
}

const { images } = Astro.props;

  const COMING_SOON = {
    src: 'https://images.unsplash.com/photo-1573164713988-8665fc963095?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&h=675&q=80',
    alt: 'Coming Soon',
    title: 'Coming Soon',
    description: '¡Más proyectos increíbles próximamente!'
  };

  const allImages = [...images, COMING_SOON];
---

<div class="carousel">
  <button class="carousel-btn prev">❮</button>

  <div class="carousel-window">
    <div class="carousel-track">
      {
        allImages.map((image) => (
          <div class="carousel-slide">
            <img src={image.src} alt={image.alt} />
            <div class="carousel-caption">
              {image.title && (
                <h2
                  data-translate
                  data-en={image.title}
                  data-es={image.title.replace("Project", "Proyecto")}
                >
                  {image.title}
                </h2>
              )}
              {image.description && (
                <p
                  data-translate
                  data-en={image.description}
                  data-es={image.description
                    .replace("platform", "plataforma")
                    .replace("website", "sitio web")
                    .replace("design", "diseño")}
                >
                  {image.description}
                </p>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <button class="carousel-btn next">❯</button>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    let index = 0;

    const track = document.querySelector(".carousel-track") as HTMLElement;
    const slides = document.querySelectorAll(".carousel-slide");
    const nextBtn = document.querySelector(".carousel-btn.next");
    const prevBtn = document.querySelector(".carousel-btn.prev");

    if (!track || slides.length === 0 || !nextBtn || !prevBtn) return;

    function updateCarousel() {
      track.style.transform = `translateX(-${index * 100}%)`;
    }

    nextBtn.addEventListener("click", () => {
      index++;
      if (index >= slides.length) {
        index = 0;
      }
      updateCarousel();
    });

    prevBtn.addEventListener("click", () => {
      index--;
      if (index < 0) {
        index = slides.length - 1;
      }
      updateCarousel();
    });
  });
</script>
