---
import "../styles/Header.css";
---

<section class="hero-wrapper">
  <header class="hero">
    <div>
      <video
        class="hero-video"
        muted
        loop
        playsinline
        preload="none"
        poster="/favicon.svg"
        data-src="/videos/NavVid01.mp4"
      ></video>
    </div>
  </header>

  <div class="hero-overlay">
    <h1
      class="animated-title"
      data-translate
      data-en="Every Component Empowers The System"
      data-es="Cada Componente Fortalece Al Sistema"
    >
      Every Component Empowers The System
    </h1>
  </div>
</section>

<!-- SCRIPT -->
<script is:inline>
  const video = document.querySelector('.hero-video');

  if (video) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {

          // Assign video when it enters the screen
          video.src = video.dataset.src;

          // Force autoplay on mobile devices
          video.muted = true;
          video.play().catch(() => {});

          // Stop observing (better performance)
          observer.disconnect();
        }
      });
    }, {
      threshold: 0.3 // It activates when 30% of the video is visible
    });

    observer.observe(video);
  }
</script>