---
import "../styles/footer.css";
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-content">
      <!-- Contact Section arriba icons -->
      <div class="footer-contact-section">
        <h4
          class="contact-title"
          data-translate
          data-en="Contact"
          data-es="Contacto"
        >
          Contact
        </h4>
        <div class="footer-icons-row">
          <div class="created-section">
            <ul class="contact-info">
              <li
                class="created-by"
                data-translate
                data-en="Created by: Alan Navarrete S"
                data-es="Creado por: Alan Navarrete S"
              >
                Created by: Alan Navarrete S
              </li>

              <li
                class="location"
                data-translate
                data-en="Location: Mexico City"
                data-es="Ubicación: Ciudad de México"
              >
                Location: Mexico City
              </li>

              <li
                class="cell"
                data-translate
                data-en="Cell: +52 5543547891"
                data-es="Cel: +52 5543547891"
              >
                Cell: +52 5543547891
              </li>
            </ul>
          </div>
          <div class="social-links-group">
            <a
              href="https://www.linkedin.com/in/alan-navarrete/"
              target="_blank"
              rel="noopener"
              aria-label="LinkedIn"
              class="social-link linkedin"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.02-1.57.27-2.12a2.211 2.211 0 0 1 2.11-1.49c1.45 0 1.62.9 1.62 2.06v4.48h2.79z"
                ></path>
              </svg>
            </a>
            <a
              href="https://github.com/SrHAO"
              target="_blank"
              rel="noopener"
              aria-label="GitHub"
              class="social-link github"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.68-.23.68-.5 0-.25-.01-.89-.01-1.74-2.77.61-3.36-1.19-3.36-1.19-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1.02.07 1.55.99 1.55.99.9 1.54 2.36 1.09 2.94.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.03A9.56 9.56 0 0 1 12 6.8c.85 0 1.72.11 2.53.33 1.91-.38 2.75-1.03 2.75-1.03.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85 0 1.34-.01 2.42-.01 2.75 0 .27.18.73.69.6A10 10 0 0 0 18 12c0-5.52-4.48-10-10-10z"
                ></path>
              </svg>
            </a>
            <a
              href="mailto:al.yoab.nav.sa@gmail.com"
              aria-label="Email"
              class="social-link email"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                ></path>
              </svg>
            </a>
            <a
              href="https://wa.me/5543547891?text=Hola%20quiero%20contactarte"
              target="_blank"
              rel="noopener"
              aria-label="WhatsApp"
              class="social-link whatsapp"
            >
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c-.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 01 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-1.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335 .157 11.892c0 2.096 .547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-1.893A11.821 1.821 0 0020.885 3.488"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <!-- Copyright LEFT aligned -->
      <div class="copyright-section">
        <p
          class="copyright"
          data-translate
          data-en="© 2024 Alan Navarrete Profile. All rights reserved."
          data-es="© 2024 Alan Navarrete Profile. Todos los derechos reservados."
        >
          &copy; 2024 Alan Navarrete Profile. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
