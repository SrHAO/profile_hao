---
import "../styles/Sidebar.css";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
---

<!-- Toggle Button -->
<input type="checkbox" id="sidebar-toggle" class="sidebar-checkbox" />

<label
  for="sidebar-toggle"
  class="sidebar-toggle"
  aria-label="Toggle navigation menu"
>
  <span class="hamburger">
    <span class="bar"></span>
    <span class="bar"></span>
  </span>
</label>

<!-- Overlay -->
<label for="sidebar-toggle" class="sidebar-overlay" aria-hidden="true"></label>

<!-- Sidebar -->
<aside class="sidebar">
  <!-- Logo SV - Same as Footer, Small Size -->
  <div class="sidebar-logo">
    <a href="/">
      <svg
        class="sidebar-logo-svg hover:scale-105 transition-all duration-300"
        role="img"
        aria-label="Logo SV - Home"
        version="1.0"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 416.217913 322.365435"
        preserveAspectRatio="xMidYMid meet"
      >
        <g
          transform="translate(-58.021257,359.574031) scale(0.100000,-0.100000)"
          fill="currentColor"
          stroke="none"
        >
          <path
            d="M2855 3594 c-270 -28 -441 -61 -643 -126 -710 -227 -1270 -722 -1515 -1338 -92 -231 -117 -374 -117 -680 0 -146 5 -222 26 -360 14 -96 29 -179 34 -184 5 -5 12 13 16 40 4 27 22 93 41 148 237 685 820 1290 1462 1517 181 64 270 80 476 86 241 7 372 -6 491 -48 239 -84 400 -209 515 -398 86 -143 120 -345 84 -507 -72 -327 -414 -594 -780 -609 -55 -2 -89 -2 -75 1 14 2 52 9 85 15 263 45 491 207 612 435 23 44 49 107 57 140 20 79 21 223 1 299 -74 281 -356 440 -649 365 -104 -26 -183 -70 -267 -148 -157 -146 -215 -288 -208 -509 4 -103 6 -112 48 -200 24 -51 53 -100 63 -109 23 -22 23 -11 -3 56 -16 42 -22 79 -22 160 -2 99 0 109 32 177 40 86 135 184 221 228 46 24 70 29 151 33 127 6 189 -12 258 -74 124 -112 153 -284 74 -452 -32 -69 -152 -192 -236 -241 -133 -78 -310 -117 -495 -108 -183 8 -323 59 -487 175 -157 111 -237 202 -338 386 l-64 116 -7 -37 c-15 -87 -19 -292 -7 -371 25 -170 93 -352 181 -483 90 -133 282 -308 438 -398 243 -141 477 -206 777 -217 289 -10 474 17 705 103 491 183 835 558 931 1013 17 81 22 138 21 250 0 221 -43 402 -143 603 -211 425 -644 764 -1148 899 -112 30 -125 31 -364 36 -278 5 -321 0 -582 -68 -234 -61 -356 -105 -541 -195 -286 -141 -524 -312 -754 -544 -123 -124 -183 -195 -294 -352 -49 -70 -38 -38 22 64 181 304 500 616 845 826 153 93 397 205 554 255 469 147 1150 202 1738 139 53 -5 59 -4 47 9 -41 50 -448 144 -722 167 -133 11 -486 21 -545 15z m284 -475 c381 -83 694 -319 851 -643 64 -131 89 -225 96 -361 11 -193 -19 -337 -107 -507 -74 -141 -213 -296 -346 -386 -77 -51 -83 -55 -83 -45 0 4 17 19 38 33 52 34 205 184 257 250 93 120 168 309 187 473 36 306 -81 610 -325 844 -193 184 -393 283 -716 354 l-86 19 70 -5 c39 -3 112 -15 164 -26z m-159 -164 c391 -93 668 -291 814 -583 30 -60 47 -102 42 -102 -3 0 -33 48 -68 107 -131 220 -322 370 -595 464 -130 45 -259 62 -478 62 -170 0 -203 -2 -313 -27 -319 -70 -618 -218 -902 -444 -185 -147 -419 -407 -560 -622 -75 -115 -177 -322 -220 -445 -37 -106 -51 -127 -38 -55 86 473 465 987 983 1335 126 84 388 213 525 259 186 61 304 77 540 71 134