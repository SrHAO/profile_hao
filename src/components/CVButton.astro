---
import "../styles/cv-button.css";

const { variant = "primary" } = Astro.props;
---

<div class="cv-btn-wrapper">
  <a
    href="#"
    class={`cv-btn ${variant === "outline" ? "cv-btn-outline" : ""}`}
    data-en="/CV/Alan_Navarrete_En.pdf"
    data-es="/CV/Alan_Navarrete_Es.pdf"
    data-name-en="CV_Alan_Navarrete_EN.pdf"
    data-name-es="CV_Alan_Navarrete_ES.pdf"
    data-en-label="Download CV"
    data-es-label="Descargar CV"
  >
    Download CV
  </a>
</div>

<style>
  .cv-btn-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    margin: 2rem 0;
  }
</style>

<script>
  function initCVButton() {
    const btn = document.querySelector(".cv-btn") as HTMLAnchorElement;
    if (!btn) return;

    const lang =
      localStorage.getItem("lang") || document.documentElement.lang || "en";
    const isSpanish = lang.startsWith("es");

    const path = isSpanish ? btn.dataset.es : btn.dataset.en;
    const name = isSpanish ? btn.dataset.nameEs : btn.dataset.nameEn;
    const label = isSpanish ? btn.dataset.esLabel : btn.dataset.enLabel;

    btn.href = path || "#";
    btn.download = name || "";
    btn.textContent = label || "Download CV";
  }

  // Initial load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCVButton);
  } else {
    initCVButton();
  }

  // Listen for language changes (integrate with existing system)
  document.addEventListener("langchange", initCVButton);
  new MutationObserver(() => initCVButton()).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["lang"],
  });
</script>
